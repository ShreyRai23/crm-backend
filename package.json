{
  "name": "mini-crm-backend",
  "version": "1.0.0",
  "description": "AI-Native B2C Mini CRM Backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently --names \"CRM,CHANNEL\" --prefix-colors \"cyan,magenta\" \"nodemon src/server.js\" \"nodemon channel-service/server.js\"",
    "start": "concurrently --names \"CRM,CHANNEL\" --prefix-colors \"cyan,magenta\" \"node src/server.js\" \"node channel-service/server.js\"",
    "start:crm": "node src/server.js",
    "start:channel": "node channel-service/server.js",
    "dev:crm": "nodemon src/server.js",
    "dev:channel": "nodemon channel-service/server.js",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "p-limit": "^3.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
